{
  "name": "benchmark-styling",
  "version": "1.0.0",
  "main": "index.ts",
  "packageManager": "bun@1.2.5",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "dependencies": {
    "expo": "~54.0.22",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-unistyles": "^3.2.2",
    "tailwindcss": "~4.1.16",
    "uniwind": "~1.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas:build:android:local": "eas build -p android --local --output ./builds/benchmark-styling.apk",
    "eas:build:ios:local": "eas build -p ios --local --output ./builds/benchmark-styling.ipa"
  },
  "patchedDependencies": {
    "uniwind@1.0.5": "patches/uniwind@1.0.5.patch"
  }
}
