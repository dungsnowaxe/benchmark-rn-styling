{
  "name": "benchmark-styling",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas:build:android:local": "eas build -p android --local --output ./builds/benchmark-styling.apk",
    "eas:build:ios:local": "eas build -p ios --local --output ./builds/benchmark-styling.ipa",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "expo": "^56.0.0",
    "expo-constants": "~56.0.16",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.8",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-unistyles": "^3.2.5",
    "tailwindcss": "~4.3.2",
    "uniwind": "~1.10.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@types/react": "~19.2.14",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "packageManager": "bun@1.2.5"
}
